/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running cmd parameters
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run trana for CMD

    Use as follows:
        nextflow run haeger/main.nf -profile singularity,cmd --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    executor                    = 'slurm'
    queue                       = 'low'
}

params {
    outdir                      = "/fs1/results/trana"

    config_profile_name         = 'cmd profile'
    config_profile_description  = 'CMD High performance profile'

    // Databases
    db                          = '/fs1/pipelines/trana-dev/assets/databases/emu_database'

    // Limit resources so that this can run on GitHub Actions
    max_cpus                    = 60
    max_memory                  = '300.GB'
    max_time                    = '48.h'

    // Reads
    save_merged_reads           = false

    // Schema
    nextflow_schema             = "${projectDir}/nextflow_schema.json"

    // Boilerplate
    containers_dir              = "/fs1/resources/containers"
    publish_dir_overwrite       = true
    run_trana                   = true
    copy_to_cron_dir            = false
    offline                     = true
    sequencing_run              = null
    fastq_pass                  = params.sequencing_run ? "${params.sequencing_run}/fastq_pass" : null

    // CDM export paths (subdirectories under outdir)
    cdmDir                      = "cdm"

    trana_results_paths = [
        nanostats_txt: "${outdir}/nanoplot/%s_nanoplot_unprocessedNanoStats.txt"
    ]
}


singularity {
    enabled = true
    runOptions = '--bind /fs1/ --bind /fs2/ --bind /local/ --bind /mnt/beegfs/'
    cacheDir = "/fs1/resources/containers"
}

includeConfig 'conf/modules.config'

profiles {
    test { includeConfig 'conf/test.config' }
}
